{
  "name": "aegis-lab",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=25.3.0"
  },
  "scripts": {
    "dev": "vite",
    "dev:addin": "echo 'Open http://localhost:5173/addin-debug.html' && vite",
    "build": "tsgo -b && vite build",
    "lint": "biome check .",
    "format": "biome check --write .",
    "lint:style": "stylelint --allow-empty-input 'src/**/*.css'",
    "fix:style": "stylelint --allow-empty-input --fix 'src/**/*.css'",
    "preview": "vite preview",
    "prepare": "simple-git-hooks",
    "deploy": "pnpm run build && wrangler deploy",
    "cf:build": "vite build",
    "cf:deploy": "wrangler deploy",
    "sandbox:create": "tsx scripts/create-sandbox-page.ts",
    "sandbox:create-user": "tsx scripts/create-user-sandbox-page.ts",
    "sandbox:activity": "tsx scripts/generate-activity-data.ts",
    "docs:sync-catalog": "tsx scripts/sync-storybook-catalog.ts",
    "docs:generate-ap-index": "tsx scripts/generate-anti-pattern-index.ts",
    "lint:text": "tsx scripts/text-linter/index.ts",
    "lint:text:fix": "tsx scripts/text-linter/index.ts --fix",
    "lint:translation": "tsx scripts/translation-checker/index.ts",
    "lint:translation:fix": "tsx scripts/translation-checker/index.ts --fix",
    "translation:generate": "tsx scripts/translation-checker/tools/generate-terminology.ts",
    "lint:eslint-custom": "pnpm exec eslint",
    "scan:anti-patterns": "tsx scripts/scan-anti-patterns.ts",
    "loc-sync:drift": "tsx skills/loc-sync/scripts/detect-drift.ts",
    "loc-sync:drift-report": "tsx scripts/loc-sync-drift-report.ts",
    "loc-sync:auto": "tsx scripts/loc-sync-auto.ts",
    "loc-sync:run": "bash scripts/loc-sync-run.sh",
    "loc-sync:capture-refs": "tsx scripts/loc-sync-capture-references.ts",
    "hueron-sync:drift": "tsx skills/hueron-sync/scripts/detect-drift.ts",
    "test": "vitest run",
    "test:skills": "vitest run scripts/skill-eval/",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:update": "playwright test --update-snapshots",
    "test:e2e:report": "playwright show-report",
    "test:e2e:headed": "playwright test --headed --workers=1",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@cloudflare/vite-plugin": "^1.31.1",
    "@legalforce/aegis-icons": "^2.13.0",
    "@legalforce/aegis-illustrations": "^2.1.5",
    "@legalforce/aegis-logos": "^2.3.0",
    "@legalforce/aegis-react": "^2.48.2",
    "@legalforce/aegis-textures": "^0.0.1",
    "@legalforce/aegis-tokens": "^2.13.2",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@xyflow/react": "^12.10.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.1",
    "react-syntax-highlighter": "^16.1.1",
    "recharts": "^3.7.0",
    "remark-gfm": "^4.0.1",
    "wrangler": "^4.81.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@legalforce/aegis-mcp-server": "1.0.1",
    "@legalforce/stylelint-config-aegis": "0.1.1",
    "@playwright/mcp": "^0.0.68",
    "@playwright/test": "^1.58.2",
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^24.12.0",
    "@types/prompts": "^2.4.9",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@typescript-eslint/parser": "^8.57.0",
    "@typescript-eslint/rule-tester": "^8.57.0",
    "@typescript-eslint/utils": "^8.57.0",
    "@typescript/native-preview": "7.0.0-dev.20260118.1",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.0.3",
    "glob": "^11.1.0",
    "jsdom": "^29.0.2",
    "prompts": "^2.4.2",
    "simple-git-hooks": "^2.13.1",
    "stylelint": "^16.26.1",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.7",
    "vitest": "^4.0.18",
    "yaml": "^2.8.2"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec tsgo -b && pnpm format && pnpm fix:style && pnpm lint:eslint-custom && git add -u",
    "post-merge": "git diff-tree -r --name-only --no-commit-id ORIG_HEAD HEAD | grep -q pnpm-lock.yaml && echo '📦 pnpm-lock.yaml changed, running pnpm install...' && pnpm install || true"
  },
  "packageManager": "pnpm@10.28.0"
}

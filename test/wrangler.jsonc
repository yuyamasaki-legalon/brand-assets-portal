{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "aegis-lab",
  "compatibility_date": "2024-11-14",
  "workers_dev": true,
  "main": "src/worker.ts",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*"]
  },
  "vars": {
    "GITHUB_REPO_URL": "https://github.com/legalforce/aegis-lab"
  },
  "d1_databases": [
    {
      "binding": "COMMENTS_DB",
      "database_name": "aegis-lab-comments",
      "database_id": "7dee9206-447b-49ae-ae66-f244376fffc2"
    }
  ]
}

{
  "globalHideSelectors": [
    "[class*='FloatingSourceCodeViewer']",
    "[class*='floating-source-code']",
    "[class*='intercom']",
    "[data-testid='help-chat']",
    "[data-testid='analytics']",
    "[class*='feature-flag-banner']"
  ],
  "skipEntries": [
    "word-addin/*",
    "word-addin-standalone/*"
  ],
  "tolerances": {
    "maxDiffPixelRatio": 0.05,
    "threshold": 0.2
  },
  "screenshot": {
    "viewport": { "width": 1440, "height": 900 },
    "waitForSelector": "main.aegis-PageLayoutContent, #root",
    "waitTimeout": 10000,
    "networkIdleTimeout": 500
  }
}
